{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook-launch.sh",
						"args": ["__NODE_BIN__", "${CLAUDE_PLUGIN_ROOT}/__HOOK_ENTRY__"]
					}
				]
			}
		],
		"CwdChanged": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook-launch.sh",
						"args": ["__NODE_BIN__", "${CLAUDE_PLUGIN_ROOT}/__HOOK_ENTRY__"]
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook-launch.sh",
						"args": ["__NODE_BIN__", "${CLAUDE_PLUGIN_ROOT}/__HOOK_ENTRY__"]
					}
				]
			}
		],
		"FileChanged": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook-launch.sh",
						"args": ["${CLAUDE_PLUGIN_ROOT}/scripts/doorbell.sh"],
						"asyncRewake": true,
						"timeout": 20
					}
				]
			}
		]
	}
}
