{
	"compaction": {
		"enabled": false
	},
	"entwurfProvider": {
		"appendSystemPrompt": false,
		"settingSources": [],
		"strictMcpConfig": true,
		"showToolNotifications": true,
		"tools": ["Read", "Bash", "Edit", "Write"],
		"skillPlugins": [],
		"permissionAllow": ["Read(*)", "Bash(*)", "Edit(*)", "Write(*)", "mcp__*"],
		"disallowedTools": [
			"AskUserQuestion",
			"CronCreate",
			"CronDelete",
			"CronList",
			"EnterPlanMode",
			"EnterWorktree",
			"ExitPlanMode",
			"ExitWorktree",
			"Monitor",
			"NotebookEdit",
			"PushNotification",
			"RemoteTrigger",
			"TaskCreate",
			"TaskGet",
			"TaskList",
			"TaskOutput",
			"TaskStop",
			"TaskUpdate",
			"WebFetch",
			"WebSearch"
		],
		"codexDisabledFeatures": ["image_generation", "tool_suggest", "tool_search", "multi_agent", "apps", "memories"],
		"mcpServers": {
			"entwurf-bridge": {
				"command": "/path/to/entwurf/mcp/entwurf-bridge/start.sh",
				"args": []
			}
		}
	}
}
